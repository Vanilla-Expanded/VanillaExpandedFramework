<Defs>
	<StatDef>
		<defName>VEF_VerbRangeFactor</defName>
		<label>weapon range factor</label>
		<labelForFullStatList>weapon range factor (people)</labelForFullStatList>
		<description>The range on weapons is multiplied by this value.</description>
		<category>PawnCombat</category>
		<defaultBaseValue>1</defaultBaseValue>
		<hideAtValue>1</hideAtValue>
		<minValue>0</minValue>
		<toStringStyle>PercentOne</toStringStyle>
		<toStringStyleUnfinalized>FloatTwo</toStringStyleUnfinalized>
		<displayPriorityInCategory>4050</displayPriorityInCategory>
	</StatDef>
	<StatDef>
		<defName>VEF_EnergyShieldEnergyMaxOffset</defName>
		<label>Shield max energy offset</label>
		<description>Offset of the maximum shield energy that the user can boost through various means.</description>
		<category>PawnCombat</category>
		<minValue>0</minValue>
		<defaultBaseValue>0</defaultBaseValue>
		<toStringStyle>FloatOne</toStringStyle>
		<hideAtValue>0</hideAtValue>
		<displayPriorityInCategory>4050</displayPriorityInCategory>
		<cacheable>true</cacheable>
	</StatDef>
	<StatDef>
		<defName>VEF_EnergyShieldEnergyMaxFactor</defName>
		<label>Shield max energy factor</label>
		<description>Factor of the maximum shield energy that the user can boost through various means.</description>
		<category>PawnCombat</category>
		<minValue>0</minValue>
		<defaultBaseValue>1</defaultBaseValue>
		<hideAtValue>1</hideAtValue>
		<toStringStyle>PercentZero</toStringStyle>
		<displayPriorityInCategory>4050</displayPriorityInCategory>
		<cacheable>true</cacheable>
	</StatDef>
	<StatDef>
		<defName>VEF_MeleeAttackDamageFactor</defName>
		<label>melee attack damage factor</label>
		<description>A multiplier on melee attack damage.</description>
		<category>PawnCombat</category>
		<minValue>0</minValue>
		<hideAtValue>1</hideAtValue>
		<defaultBaseValue>1</defaultBaseValue>
		<toStringStyle>PercentZero</toStringStyle>
		<displayPriorityInCategory>3400</displayPriorityInCategory>
	</StatDef>
	<StatDef>
		<defName>VEF_RangeAttackDamageFactor</defName>
		<label>range attack damage factor</label>
		<description>A multiplier on range attack damage.</description>
		<category>PawnCombat</category>
		<minValue>0</minValue>
		<hideAtValue>1</hideAtValue>
		<defaultBaseValue>1</defaultBaseValue>
		<toStringStyle>PercentZero</toStringStyle>
		<displayPriorityInCategory>3400</displayPriorityInCategory>
	</StatDef>
	<StatDef>
		<!--  -->
		<defName>VEF_FoodCapacityMultiplier</defName>
		<label>body food capacity multiplier</label>
		<description>Increases the size of the pawn's hunger bar. This does not affect hunger</description>
		<alwaysHide>true</alwaysHide>
		<category>BasicsNonPawnImportant</category>
		<toStringStyle>FloatOne</toStringStyle>
		<defaultBaseValue>1.0</defaultBaseValue>
		<minValue>-99</minValue>
	</StatDef>
	<StatDef>
		<defName>VEF_GrowthPointMultiplier</defName>
		<label>growth point multiplier</label>
		<description>Increases the amount of growth points accumulated by children when learning</description>
		<alwaysHide>true</alwaysHide>
		<category>BasicsNonPawnImportant</category>
		<toStringStyle>FloatOne</toStringStyle>
		<defaultBaseValue>1.0</defaultBaseValue>
		<minValue>0</minValue>
	</StatDef>
	<!-- Rendering -->
	<!--These are hidden StatDefs used to modify the size of any pawn. Note that size has a falloff upwards,
		while downwards will 'chibify' the character.
		As of writing 2024-02-08 does NOT affect animals, but we could if we want.-->
	<StatDef>
		<!-- Used to modify a pawn based on their current size.
					E.g. +1 for a size 1.0 human would rougly double size. +1 for a size 4 Thumbo would increase it by ~25%-->
		<defName>VEF_BodySize_Offset</defName>
		<label>body size offset</label>
		<description>Increases the size of the pawn relative to their current size</description>
		<alwaysHide>true</alwaysHide>
		<category>BasicsPawn</category>
		<toStringStyle>FloatOne</toStringStyle>
		<defaultBaseValue>0.0</defaultBaseValue>
		<minValue>-99</minValue>
	</StatDef>
	<StatDef>
		<!--Roughly multiplies size.-->
		<defName>VEF_BodySize_Multiplier</defName>
		<label>body size multiplier</label>
		<description>Increases the size of the pawn by a multiple of their current size</description>
		<alwaysHide>true</alwaysHide>
		<category>BasicsPawn</category>
		<toStringStyle>PercentZero</toStringStyle>
		<defaultBaseValue>1.0</defaultBaseValue>
		<minValue>-99</minValue>
	</StatDef>
	<StatDef>
		<defName>VEF_CosmeticBodySize_Offset</defName>
		<label>cosmetic body size offset</label>
		<description>Increases the size of the pawn relative to their current size</description>
		<alwaysHide>true</alwaysHide>
		<category>BasicsPawn</category>
		<toStringStyle>FloatOne</toStringStyle>
		<defaultBaseValue>0.0</defaultBaseValue>
		<minValue>-99</minValue>
	</StatDef>
	<StatDef>
		<defName>VEF_CosmeticBodySize_Multiplier</defName>
		<label>cosmetic body size multiplier</label>
		<description>Increases the size of the pawn by a multiple of their current size</description>
		<alwaysHide>true</alwaysHide>
		<category>BasicsPawn</category>
		<toStringStyle>PercentZero</toStringStyle>
		<defaultBaseValue>1.0</defaultBaseValue>
		<minValue>-99</minValue>
	</StatDef>
	<StatDef>
		<!--Scales the character's head on the rendering step. Note that scaled down pawns already get larger heads and scaled up slghtly smaller-->
		<defName>VEF_HeadSize_Cosmetic</defName>
		<label>head size multiplier</label>
		<alwaysHide>true</alwaysHide>
		<category>BasicsPawn</category>
		<minValue>0.05</minValue>
		<toStringStyle>PercentZero</toStringStyle>
		<defaultBaseValue>1.0</defaultBaseValue>
	</StatDef>
	<StatDef>
		<!-- Moves the pawn up or down in rendering terms-->
		<defName>VEF_PawnRenderPosOffset</defName>
		<label>pawn render offset</label>
		<description>Modifies the pawn's rendered position in y-axis.</description>
		<alwaysHide>true</alwaysHide>
		<category>BasicsPawn</category>
		<toStringStyle>FloatOne</toStringStyle>
		<defaultBaseValue>0.0</defaultBaseValue>
		<minValue>-99</minValue>
	</StatDef>
	<StatDef>
		<defName>VEF_MassCarryCapacity</defName>
		<label>Mass carry capacity</label>
		<description>Total mass carrying capacity of the pawn in caravans.</description>
		<workerClass>VEF.Pawns.StatWorker_MassCarryCapacity</workerClass>
		<category>BasicsPawn</category>
		<defaultBaseValue>0</defaultBaseValue>
		<hideAtValue>0</hideAtValue>
		<minValue>0</minValue>
		<toStringStyle>FloatTwoOrThree</toStringStyle>
		<formatString>{0} kg</formatString>
		<formatStringUnfinalized>{0} kg</formatStringUnfinalized>
		<parts>
			<li Class="StatPart_Quality">
				<factorAwful>0.5</factorAwful>
				<factorPoor>0.8</factorPoor>
				<factorNormal>1</factorNormal>
				<factorGood>1.2</factorGood>
				<factorExcellent>1.5</factorExcellent>
				<factorMasterwork>1.7</factorMasterwork>
				<factorLegendary>2</factorLegendary>
			</li>
		</parts>
	</StatDef>
	<StatDef>
		<defName>VEF_MTBLovinFactor</defName>
		<label>MTB Lovin Factor</label>
		<description>A factor of the mean time between (MTB) this person looking for some lovin'.</description>
		<category>BasicsPawn</category>
		<defaultBaseValue>1</defaultBaseValue>
		<minValue>0</minValue>
		<toStringStyle>PercentZero</toStringStyle>
		<showOnHumanlikes>true</showOnHumanlikes>
		<showOnAnimals>false</showOnAnimals>
		<showOnMechanoids>false</showOnMechanoids>
		<showOnEntities>false</showOnEntities>
		<showDevelopmentalStageFilter>Adult</showDevelopmentalStageFilter>
	</StatDef>
	<StatDef Name="VEF_ThoughtDurationBase" Abstract="True">
		<category>BasicsPawn</category>
		<defaultBaseValue>1</defaultBaseValue>
		<minValue>0</minValue>
		<hideAtValue>1</hideAtValue>
		<toStringStyle>PercentZero</toStringStyle>
		<showOnHumanlikes>true</showOnHumanlikes>
		<showOnAnimals>false</showOnAnimals>
		<showOnMechanoids>false</showOnMechanoids>
		<showOnEntities>false</showOnEntities>
	</StatDef>
	<StatDef ParentName="VEF_ThoughtDurationBase">
		<defName>VEF_PositiveThoughtDurationFactor</defName>
		<label>thought duration factor - positive</label>
		<description>The duration of positive thoughts is multiplied by this value.</description>
	</StatDef>
	<StatDef ParentName="VEF_ThoughtDurationBase">
		<defName>VEF_NeutralThoughtDurationFactor</defName>
		<label>thought duration factor - neutral</label>
		<description>The duration of neutral thoughts is multiplied by this value.</description>
	</StatDef>
	<StatDef ParentName="VEF_ThoughtDurationBase">
		<defName>VEF_NegativeThoughtDurationFactor</defName>
		<label>thought duration factor - negative</label>
		<description>The duration of negative thoughts is multiplied by this value.</description>
	</StatDef>
	<StatDef>
		<defName>VEF_RangedDodgeChance</defName>
		<label>ranged dodge chance</label>
		<description>Chance to dodge a ranged attack that would've otherwise hit, or (if negative) get hit by a ranged attack that was meant for a different target.</description>
		<category>PawnCombat</category>
		<neverDisabled>true</neverDisabled>
		<defaultBaseValue>0</defaultBaseValue>
		<!-- Going below 100% would make free interceptions/getting hit by unintended target more likely. -->
		<!-- Some factors (like distance, friendly fire chance, body size) could make values lower than -->
		<!-- 100% have effect, but let's keep some limit here to prevent stuff from being too crazy. -->
		<minValue>-1</minValue>
		<!-- No effect above 100%, so let's cap it there. -->
		<maxValue>1</maxValue>
		<toStringStyle>PercentZero</toStringStyle>
		<toStringStyleUnfinalized>FloatTwo</toStringStyleUnfinalized>
		<noSkillOffset>0</noSkillOffset>
		<displayPriorityInCategory>4101</displayPriorityInCategory>
		<showDevelopmentalStageFilter>Child, Adult</showDevelopmentalStageFilter>
	</StatDef>
</Defs>