<Defs>


	<StatDef>
		<defName>VEF_EnergyShieldEnergyMaxBuilding</defName>
		<label>shield max energy</label>
		<description>The maximum energy the shield can have. More energy allows the shield to absorb more damage.</description>
		<category>Building</category>
		<defaultBaseValue>0</defaultBaseValue>
		<minValue>0</minValue>
		<toStringStyle>Integer</toStringStyle>
		<formatString>{0}00</formatString>
		<hideAtValue>0</hideAtValue>
		<showIfUndefined>false</showIfUndefined>
		<displayPriorityInCategory>5000</displayPriorityInCategory>
	</StatDef>

	<StatDef>
		<defName>VEF_EnergyShieldRechargeRateBuilding</defName>
		<label>shield recharge rate</label>
		<description>The rate at which the shield recharges energy per second, as long as it is not broken.</description>
		<category>Building</category>
		<workerClass>VEF.Apparels.StatWorker_MultiplyBy100</workerClass>
		<defaultBaseValue>0</defaultBaseValue>
		<minValue>0</minValue>
		<toStringStyle>FloatTwo</toStringStyle>
		<formatString>{0}/s</formatString>
		<hideAtValue>0</hideAtValue>
		<showIfUndefined>false</showIfUndefined>
		<displayPriorityInCategory>5000</displayPriorityInCategory>
	</StatDef>

	<StatDef>
		<defName>VEF_EnergyShieldRadiusBuilding</defName>
		<label>shield radius</label>
		<description>The radius of the energy shield protection.</description>
		<category>Building</category>
		<defaultBaseValue>0</defaultBaseValue>
		<minValue>0</minValue>
		<toStringStyle>FloatOne</toStringStyle>
		<formatString>{0} c</formatString>
		<hideAtValue>0</hideAtValue>
		<showIfUndefined>false</showIfUndefined>
		<displayPriorityInCategory>5000</displayPriorityInCategory>
	</StatDef>


	<!-- Perhaps it would be smart to use load folders and add it to Biotech one, but for now it seems pointless given it would be the only thing in there. -->
	<StatDef MayRequire="Ludeon.RimWorld.Biotech">
		<defName>VEF_BuildingLearningRateOffset</defName>
		<label>learning rate</label>
		<!-- Same description as school desk's CompProperties_StatEntry was using. -->
		<description>A multiplier on how quickly children learn during lessons which are assisted by this.</description>
		<category>Building</category>
		<defaultBaseValue>1</defaultBaseValue>
		<toStringStyle>PercentZero</toStringStyle>
		<showIfUndefined>false</showIfUndefined>
		<!-- Don't allow for negative learning rate. -->
		<minValue>0</minValue>
		<!-- Same value as school desk's CompProperties_StatEntry was using. -->
		<displayPriorityInCategory>300</displayPriorityInCategory>
	</StatDef>
	
	<StatDef>
		<defName>VEF_BuildingBreakdownFactor</defName>
		<label>breakdown factor</label>
		<description>A multiplier on how often this building breaks down.</description>
		<category>Building</category>
		<defaultBaseValue>1</defaultBaseValue>
		<toStringStyle>PercentZero</toStringStyle>
		<showIfUndefined>false</showIfUndefined>
		<displayPriorityInCategory>300</displayPriorityInCategory>
	</StatDef>
	<StatDef>
		<defName>VEF_BuildingMaxOverclockFactor</defName>
		<label>maximum overclock factor</label>
		<description>A multiplier on the maximum possible overclock of a factory.</description>
		<category>Building</category>
		<defaultBaseValue>1</defaultBaseValue>
		<toStringStyle>PercentZero</toStringStyle>
		<showIfUndefined>false</showIfUndefined>
		<displayPriorityInCategory>301</displayPriorityInCategory>
	</StatDef>
	<StatDef>
		<defName>VEF_FactoryHeatPerSecondFactor</defName>
		<label>heat per second factor</label>
		<description>A multiplier on the heat per second produced by a factory.</description>
		<category>Building</category>
		<defaultBaseValue>1</defaultBaseValue>
		<toStringStyle>PercentZero</toStringStyle>
		<showIfUndefined>false</showIfUndefined>
		<displayPriorityInCategory>302</displayPriorityInCategory>
	</StatDef>
</Defs>